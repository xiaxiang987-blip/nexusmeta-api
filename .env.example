# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ==================== AI 服务配置 ====================
# 支持 DeepSeek（推荐，国内直连）、OpenAI、通义千问等兼容 OpenAI SDK 的服务

# API Key
# 获取：https://platform.deepseek.com/（国内）或 https://platform.openai.com/（国际）
OPENAI_API_KEY=sk-your-api-key-here

# API 地址（兼容 OpenAI SDK 格式）
# DeepSeek: https://api.deepseek.com/v1
# OpenAI:  https://api.openai.com/v1（需科学上网）
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 模型
# DeepSeek: deepseek-chat（推荐，中文命理极强且便宜）
# OpenAI:   gpt-4o
OPENAI_MODEL=deepseek-chat

# ==================== 数据库 ====================
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexusmeta?schema=public"

# ==================== 服务器 ====================
PORT=3001
NODE_ENV=development

# ==================== JWT ====================
JWT_SECRET=nexusmeta_super_secret_jwt_key_2024_change_in_production

# ==================== CORS ====================
CORS_ORIGIN=https://xuanmi.net,https://www.xuanmi.net,http://localhost:5173,http://localhost:3000

# ==================== 限流 ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
